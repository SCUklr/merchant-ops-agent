# 选一个后端测 LangChain（脚本会优先用 LLM_BACKEND，否则看谁有 Key）
# LLM_BACKEND=deepseek   # 或 qwen

# DeepSeek（OpenAI 兼容 API）
DEEPSEEK_API_KEY=your_deepseek_api_key
# 可选，默认 deepseek-chat
# DEEPSEEK_MODEL=deepseek-chat

# 通义千问（阿里云 DashScope，需 pip install dashscope，已在 requirements 中）
DASHSCOPE_API_KEY=your_dashscope_api_key
# 可选，默认 qwen-turbo
# QWEN_MODEL=qwen-turbo

# 仅验证 import，不调 API：ONLY_IMPORTS=1
